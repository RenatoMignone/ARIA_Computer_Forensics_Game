# ─────────────────────────────────────────────────────────────────
# ARIA — Don't Trust the Machine
# Environment Configuration
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Mode Selection ───────────────────────────────────────────────────

# Scripted Mode (default): works 100% offline, no API key needed.
# All ARIA responses come from aria_responses.json (18 pre-authored claims).
VITE_LIVE_AI=false

# ── Live Gemini AI Mode ──────────────────────────────────────────────
# Uncomment and fill in to enable dynamic AI responses via Gemini 2.5 Flash.
# Get a free API key at: https://aistudio.google.com/apikey
#
# VITE_LIVE_AI=true
# VITE_GEMINI_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────────────────────────────
# IMPORTANT: Never commit your actual .env file to git.
# The .gitignore already excludes it.
# ─────────────────────────────────────────────────────────────────
